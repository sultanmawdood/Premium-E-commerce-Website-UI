# NPM Security Configuration
# Enforce package scope and security settings

# Registry configuration for scoped packages
@kingsports:registry=https://npm.pkg.github.com/

# Security settings
audit-level=high
fund=false
save-exact=true

# Package installation security
package-lock=true

# Engine strict mode
engine-strict=true

# Progress and logging
progress=false
loglevel=warn

# Security audit configuration
audit=true